<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.effect.Reflection?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<BorderPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="app.carrental.History">

    <center>
        <TableView fx:id="historyTable" prefHeight="400.0" prefWidth="441.0">
            <columns>
                    <TableColumn fx:id="historyIdCol" prefWidth="72.0" text="History ID" />
                    <TableColumn fx:id="rentalIdCol" prefWidth="62.0" text="Rental ID" />
                    <TableColumn fx:id="clientCol" prefWidth="96.0" text="Client" />
                    <TableColumn fx:id="carIdCol" prefWidth="68.0" text="Car ID" />
                    <TableColumn fx:id="daysCol" prefWidth="44.0" text="Days" />
                    <TableColumn fx:id="totalCol" prefWidth="79.0" text="Total Price" />
                    <TableColumn fx:id="dateCol" prefWidth="139.0" text="Returned On" />
            </columns>
        </TableView>
    </center>
   <left>
      <AnchorPane prefHeight="400.0" prefWidth="174.0" style="-fx-background-color: #000000;" BorderPane.alignment="CENTER">
         <children>
            <ImageView fitHeight="88.0" fitWidth="159.0" layoutX="8.0" layoutY="82.0">
               <image>
                  <Image url="@img/image.png" />
               </image>
               <effect>
                  <Reflection bottomOpacity="0.16" fraction="0.5" topOffset="-10.0" topOpacity="0.33" />
               </effect>
            </ImageView>
            <Text boundsType="VISUAL" fill="#ffc200" layoutX="19.0" layoutY="256.0" opacity="0.64" text="This is the Client and Car history" textAlignment="JUSTIFY" wrappingWidth="136.197265625">
               <font>
                  <Font name="Calibri Bold" size="12.0" />
               </font>
            </Text>
            <Button fx:id="backToMainMenuThree" layoutX="20.0" layoutY="313.0" mnemonicParsing="false" onAction="#userBackToMainMenuThree" prefHeight="32.0" prefWidth="133.0" text="Back" />
         </children>
      </AnchorPane>
   </left>

</BorderPane>
